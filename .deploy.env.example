# Konfigurasi push-deploy.sh — SALIN file ini menjadi .deploy.env lalu isi.
# (.deploy.env di-.gitignore, jadi IP/user server TIDAK ikut ter-commit.)

SSH_HOST=123.45.67.89                              # IP atau domain server
SSH_USER=root                                       # user SSH
SSH_PORT=22                                          # port SSH (default 22)
REMOTE_DIR=/var/www/amidigital.sistemedu.com         # path project di server
BRANCH=master                                        # branch yang di-deploy
